# ============================================================
#  SisPode Bot — configuração (copie para .env e preencha)
#  O .env NUNCA deve ser commitado (está no .gitignore).
# ============================================================

# Token do bot, criado no @BotFather (passo a passo no INSTALACAO.md)
BOT_TOKEN=

# URL do Realtime Database (a mesma usada pela extensão)
FIREBASE_URL=https://plenario-podemos-default-rtdb.firebaseio.com

# Chat do grupo da equipe (número NEGATIVO, ex.: -1001234567890).
# É onde o cron anuncia pauta nova. Vazio = aviso automático desligado.
GRUPO_CHAT_ID=

# user_id do administrador (aprova novos analistas e recebe pedidos de acesso)
ADMIN_USER_ID=

# Palavra-chave de acesso (RECOMENDADO): quem enviá-la corretamente no privado
# do bot entra sozinho na allowlist — sem precisar cadastrar IDs aqui.
# Comparação ignora maiúsculas/minúsculas; 5 erros bloqueiam por 1 hora e o
# admin é avisado a cada entrada (remova alguém com /revogar <id>).
# Vazio = acesso só pela aprovação manual do administrador (botão Autorizar).
SENHA_ACESSO=

# (Opcional) IDs de usuário SEMPRE autorizados, separados por vírgula —
# independem da palavra-chave e não podem ser revogados pelo /revogar.
ALLOWED_USER_IDS=

# Intervalo do monitor de pauta em minutos (mínimo 5; padrão 30)
CRON_MINUTOS=30

# (Recomendado) Chave Gemini usada como transcritor padrão de TODAS as
# mensagens de voz (cota gratuita cobre; crie em aistudio.google.com).
# Vazio = cada analista transcreve na própria chave (Gemini/OpenAI);
# quem usa Anthropic fica sem voz, pois a API deles não aceita áudio.
TRANSCRIBE_GEMINI_KEY=
